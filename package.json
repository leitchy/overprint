{
  "name": "overprint",
  "version": "0.15.2",
  "private": true,
  "type": "module",
  "description": "Web-based orienteering course setting software",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "orienteering",
    "course-setting",
    "maps"
  ],
  "author": "Jim Cresswell",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "buffer": "^6.0.3",
    "immer": "^11.1.4",
    "konva": "^10.2.3",
    "ocad2geojson": "^2.1.20",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "proj4": "^2.20.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "svg-control-descriptions": "^2.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "zundo": "^2.3.0"
  }
}
